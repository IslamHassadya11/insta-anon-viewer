// Updated version with multiple proxies + better error handling
const proxies = [
  "https://corsproxy.io/?",
  "https://api.allorigins.win/raw?url=",
  "https://cors-anywhere.herokuapp.com/"   // sometimes needs visit first
];

async function fetchWithProxy(url) {
  for (let proxy of proxies) {
    try {
      const fullUrl = proxy + encodeURIComponent(url);
      const response = await fetch(fullUrl, {
        headers: { 'User-Agent': 'Mozilla/5.0' }
      });
      
      if (response.ok) {
        return await response.json();
      }
    } catch (e) {}
  }
  return null;
}

async function loadProfile() {
  const usernameInput = document.getElementById('username');
  let username = usernameInput.value.trim().toLowerCase();
  
  if (!username) {
    alert("Please enter a username");
    return;
  }

  document.getElementById('error').classList.add('hidden');
  const profileDiv = document.getElementById('profile');
  profileDiv.innerHTML = `<p class="text-center text-gray-400 py-10">Loading profile...</p>`;
  profileDiv.classList.remove('hidden');

  const url = `https://www.instagram.com/api/v1/users/web_profile_info/?username=${username}`;
  const data = await fetchWithProxy(url);

  if (!data?.data?.user) {
    document.getElementById('error').innerHTML = `
      ❌ Could not load profile.<br><br>
      Possible reasons:<br>
      • Account is private<br>
      • Instagram is blocking requests<br>
      • Try a different public account (e.g. natgeo, instagram, cristiano)<br><br>
      Try again in 1-2 minutes.
    `;
    document.getElementById('error').classList.remove('hidden');
    profileDiv.classList.add('hidden');
    return;
  }

  const user = data.data.user;

  let postsHTML = user.edge_owner_to_timeline_media?.edges?.length 
    ? user.edge_owner_to_timeline_media.edges.slice(0, 9).map(edge => {
        const img = edge.node.thumbnail_src || edge.node.display_url;
        return `<img onclick="enlarge('${img}')" src="${img}" class="w-full aspect-square object-cover rounded-2xl cursor-pointer hover:scale-105 transition">`;
      }).join('')
    : '<p class="col-span-3 text-center text-gray-400 py-8">No public posts visible</p>';

  profileDiv.innerHTML = `
    <div class="flex flex-col md:flex-row gap-10">
      <div onclick="enlarge('${user.profile_pic_url_hd || user.profile_pic_url}')" class="cursor-pointer">
        <img src="${user.profile_pic_url_hd || user.profile_pic_url}" class="w-56 h-56 rounded-full border-4 border-pink-500 object-cover">
      </div>
      
      <div class="flex-1">
        <h2 class="text-4xl font-bold">${user.full_name} <span class="text-gray-400">@${user.username}</span></h2>
        <p class="mt-4 text-lg">${user.biography || 'No bio available'}</p>
        
        <div class="flex gap-8 mt-6 text-xl">
          <div><b>${user.edge_followed_by.count.toLocaleString()}</b> followers</div>
          <div><b>${user.edge_follow.count.toLocaleString()}</b> following</div>
          <div><b>${user.edge_owner_to_timeline_media.count.toLocaleString()}</b> posts</div>
        </div>
      </div>
    </div>

    <h3 class="mt-12 mb-6 text-2xl font-semibold">Recent Posts</h3>
    <div class="grid grid-cols-3 gap-3">
      ${postsHTML}
    </div>

    <p class="text-center text-sm text-gray-500 mt-12">
      Stories not available in this version (need backend).<br>
      Try DolphinRadar for stories.
    </p>
  `;
}

function enlarge(src) {
  document.getElementById('modal-img').src = src;
  document.getElementById('modal').style.display = 'flex';
}

// Enter key support
document.getElementById('username').addEventListener('keypress', e => {
  if (e.key === 'Enter') loadProfile();
});
